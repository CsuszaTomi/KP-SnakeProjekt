<Window x:Class="KP_SnakeProjekt.Skins"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KP_SnakeProjekt"
        mc:Ignorable="d"
        Title="Skinek" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0d1117"
        Loaded="Window_Loaded">
    <Grid>
        <!-- Háttér díszek -->
        <Ellipse Width="400" Height="400" Fill="#1a2f1a" HorizontalAlignment="Left"
                 VerticalAlignment="Top" Margin="-150,-150,0,0" Opacity="0.4"/>
        <Ellipse Width="300" Height="300" Fill="#1a1a2f" HorizontalAlignment="Right"
                 VerticalAlignment="Bottom" Margin="0,0,-100,-100" Opacity="0.4"/>
        <Ellipse Width="150" Height="150" Fill="#2f1a2f" HorizontalAlignment="Right"
                 VerticalAlignment="Top" Margin="0,-50,-50,0" Opacity="0.3"/>
        <Ellipse Width="120" Height="120" Fill="#1a2f1a" HorizontalAlignment="Left"
                 VerticalAlignment="Bottom" Margin="-30,0,0,-30" Opacity="0.3"/>

        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- CÍM -->
            <StackPanel Grid.Row="0" Margin="0,0,0,30">
                <TextBlock Text="SKINEK" FontSize="48" FontWeight="Black"
                           Foreground="#4ade80" HorizontalAlignment="Center"
                           FontFamily="Consolas">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#4ade80" BlurRadius="24" ShadowDepth="0" Opacity="0.7"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="Válassz egy skint a kígyódhoz"
                           Foreground="#4b5563" FontSize="13"
                           FontFamily="Consolas" HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- SKIN KÁRTYÁK -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                <WrapPanel x:Name="skinPanel" HorizontalAlignment="Center">

                    <!-- Default -->
                    <Button x:Name="btnSkinDefault" Tag="default"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Margin="12" Click="SkinButton_Click">
                        <Border x:Name="borderDefault" Width="120" Height="160"
                                CornerRadius="10" Background="#161b22"
                                BorderBrush="#4ade80" BorderThickness="2">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="pack://application:,,,/img/Skins/snakebody.png"
                                       Width="48" Height="48" Margin="0,0,0,0"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <Image Source="pack://application:,,,/img/Skins/snakehead.png"
                                       Width="48" Height="48" Margin="0,0,0,12"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="ALAP" Foreground="#4ade80"
                                           FontFamily="Consolas" FontSize="12"
                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Button>

                    <!-- Blue -->
                    <Button x:Name="btnSkinBl" Tag="Bl"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Margin="12" Click="SkinButton_Click">
                        <Border x:Name="borderBl" Width="120" Height="160"
                                CornerRadius="10" Background="#161b22"
                                BorderBrush="#1f2937" BorderThickness="2">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="pack://application:,,,/img/Skins/snakebodyBl.png"
                                       Width="48" Height="48" Margin="0,0,0,0"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <Image Source="pack://application:,,,/img/Skins/snakeheadBl.png"
                                       Width="48" Height="48" Margin="0,0,0,12"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="KÉK" Foreground="#4ade80"
                                           FontFamily="Consolas" FontSize="12"
                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Button>

                    <!-- Pink -->
                    <Button x:Name="btnSkinPi" Tag="Pi"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Margin="12" Click="SkinButton_Click">
                        <Border x:Name="borderPi" Width="120" Height="160"
                                CornerRadius="10" Background="#161b22"
                                BorderBrush="#1f2937" BorderThickness="2">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="pack://application:,,,/img/Skins/snakebodyPi.png"
                                       Width="48" Height="48" Margin="0,0,0,0"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <Image Source="pack://application:,,,/img/Skins/snakeheadPi.png"
                                       Width="48" Height="48" Margin="0,0,0,12"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="PINK" Foreground="#4ade80"
                                           FontFamily="Consolas" FontSize="12"
                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Button>

                    <!-- Purple -->
                    <Button x:Name="btnSkinPu" Tag="Pu"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Margin="12" Click="SkinButton_Click">
                        <Border x:Name="borderPu" Width="120" Height="160"
                                CornerRadius="10" Background="#161b22"
                                BorderBrush="#1f2937" BorderThickness="2">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="pack://application:,,,/img/Skins/snakebodyPu.png"
                                       Width="48" Height="48" Margin="0,0,0,0"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <Image Source="pack://application:,,,/img/Skins/snakeheadPu.png"
                                       Width="48" Height="48" Margin="0,0,0,12"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="LILA" Foreground="#4ade80"
                                           FontFamily="Consolas" FontSize="12"
                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Button>

                    <!-- Red -->
                    <Button x:Name="btnSkinRed" Tag="Red"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Margin="12" Click="SkinButton_Click">
                        <Border x:Name="borderRed" Width="120" Height="160"
                                CornerRadius="10" Background="#161b22"
                                BorderBrush="#1f2937" BorderThickness="2">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="pack://application:,,,/img/Skins/snakebodyRed.png"
                                       Width="48" Height="48" Margin="0,0,0,0"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <Image Source="pack://application:,,,/img/Skins/snakeheadRed.png"
                                       Width="48" Height="48" Margin="0,0,0,12"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="PIROS" Foreground="#4ade80"
                                           FontFamily="Consolas" FontSize="12"
                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Button>

                    <!-- Yellow -->
                    <Button x:Name="btnSkinYe" Tag="Ye"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Margin="12" Click="SkinButton_Click">
                        <Border x:Name="borderYe" Width="120" Height="160"
                                CornerRadius="10" Background="#161b22"
                                BorderBrush="#1f2937" BorderThickness="2">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="pack://application:,,,/img/Skins/snakebodyYe.png"
                                       Width="48" Height="48" Margin="0,0,0,0"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <Image Source="pack://application:,,,/img/Skins/snakeheadYe.png"
                                       Width="48" Height="48" Margin="0,0,0,12"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="SÁRGA" Foreground="#4ade80"
                                           FontFamily="Consolas" FontSize="12"
                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Button>

                    <!-- Yellow-Green -->
                    <Button x:Name="btnSkinYG" Tag="YG"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Margin="12" Click="SkinButton_Click">
                        <Border x:Name="borderYG" Width="120" Height="160"
                                CornerRadius="10" Background="#161b22"
                                BorderBrush="#1f2937" BorderThickness="2">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="pack://application:,,,/img/Skins/snakebodyYG.png"
                                       Width="48" Height="48" Margin="0,0,0,0"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <Image Source="pack://application:,,,/img/Skins/snakeheadYG.png"
                                       Width="48" Height="48" Margin="0,0,0,12"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="SÁRGA-ZÖLD" Foreground="#4ade80"
                                           FontFamily="Consolas" FontSize="12"
                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Button>

                </WrapPanel>
            </ScrollViewer>

            <!-- GOMBOK -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button x:Name="btnSelect" Content="KIVÁLASZT"
                        Height="48" Width="200" Margin="0,0,16,0"
                        Background="#4ade80" Foreground="#0d1117"
                        FontWeight="Bold" FontSize="15" BorderThickness="0"
                        Cursor="Hand" FontFamily="Consolas"
                        Click="btnSelect_Click"/>
                <Button x:Name="btnBack" Content="VISSZA"
                        Height="48" Width="200"
                        Background="#161b22" Foreground="#4ade80"
                        FontSize="15" BorderThickness="1"
                        BorderBrush="#4ade80" Cursor="Hand"
                        FontFamily="Consolas" Click="btnBack_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>