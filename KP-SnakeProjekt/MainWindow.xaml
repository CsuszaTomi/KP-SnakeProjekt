<Window x:Class="KP_SnakeProjekt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KP_SnakeProjekt"
        mc:Ignorable="d"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        Title="Snake Projekt" Height="600" Width="1000"
        Background="#0d1117" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FEJLÉC -->
        <Border Grid.Row="0"
                Background="#0d1117"
                BorderBrush="#1f2937"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- BAL – Pozíció + Almák -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Left">

                    <Border Background="#161b22" CornerRadius="8"
                            BorderBrush="#4ade80" BorderThickness="1"
                            Padding="12,6" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="POZÍCIÓ" Foreground="#4b5563"
                                       FontSize="9" FontWeight="Bold" FontFamily="Consolas"/>
                            <TextBlock x:Name="txtPos" Text="X: 0 | Y: 0"
                                       Foreground="#4ade80" FontSize="15" FontFamily="Consolas">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#4ade80" BlurRadius="6" ShadowDepth="0" Opacity="0.4"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Background="#161b22" CornerRadius="8"
                            BorderBrush="#f87171" BorderThickness="1"
                            Padding="12,6">
                        <StackPanel>
                            <TextBlock Text="MEGEVETT ALMÁK" Foreground="#4b5563"
                                       FontSize="9" FontWeight="Bold" FontFamily="Consolas"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🍎" FontSize="15" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtApples" Text="0 db"
                                           Foreground="#f87171" FontSize="15"
                                           FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- KÖZÉP – Idő -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="ELTELT IDŐ" Foreground="#4b5563" FontSize="9"
                               FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtTime" Text="00:00"
                               Foreground="#4ade80" FontSize="28" FontWeight="Black"
                               FontFamily="Consolas" HorizontalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#4ade80" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <!-- JOBB – Testhossz + Felhasználó -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right">

                    <Border Background="#161b22" CornerRadius="8"
                            BorderBrush="#f87171" BorderThickness="1"
                            Padding="12,6" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="TESTHOSSZ" Foreground="#4b5563"
                                       FontSize="9" FontWeight="Bold" FontFamily="Consolas"
                                       HorizontalAlignment="Right"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🐍" FontSize="15" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtBodyLength" Text="5"
                                           Foreground="#f87171" FontSize="15"
                                           FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#161b22" CornerRadius="8"
                            BorderBrush="#4ade80" BorderThickness="1"
                            Padding="12,6">
                        <StackPanel>
                            <TextBlock Text="JÁTÉKOS" Foreground="#4b5563"
                                       FontSize="9" FontWeight="Bold" FontFamily="Consolas"/>
                            <TextBlock x:Name="txtPlayer" Text="vendég"
                                       Foreground="#4ade80" FontSize="15" FontFamily="Consolas">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#4ade80" BlurRadius="6" ShadowDepth="0" Opacity="0.4"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- JÁTÉKTÉR -->
        <Grid Grid.Row="1" Margin="16">
            <Border BorderBrush="#1f2937"
                    BorderThickness="2"
                    CornerRadius="10"
                    Background="#000000"
                    Padding="4">
                <Border BorderBrush="#161b22"
                        BorderThickness="2"
                        CornerRadius="8">
                    <ScrollViewer x:Name="kamera"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Hidden"
                                  Background="#0a0f0a">
                        <Canvas x:Name="jatekter"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                    </ScrollViewer>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>