<Window x:Class="KP_SnakeProjekt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KP_SnakeProjekt"
        mc:Ignorable="d"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        Title="Snake Projekt" Height="600" Width="1000"
        Background="#121212" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="#252526" 
                BorderBrush="#3e3e42" 
                BorderThickness="0,0,0,2" 
                Padding="20,10">

            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,30,0">
                        <TextBlock Text="POZÍCIÓ" Foreground="#aaaaaa" FontSize="10" FontWeight="Bold"/>
                        <TextBlock x:Name="txtPos" Text="X: 0 | Y: 0" Foreground="#4da6ff" FontSize="18" FontFamily="Consolas"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,30,0">
                        <TextBlock Text="ELTELT IDŐ" Foreground="#aaaaaa" FontSize="10" FontWeight="Bold"/>
                        <TextBlock x:Name="txtTime" Text="00:00" Foreground="White" FontSize="18" FontFamily="Consolas"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="MEGEVETT ALMÁK" Foreground="#aaaaaa" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🍎" FontSize="18" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtApples" Text="0 db" Foreground="#ff4d4d" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Border BorderBrush="#3e3e42" 
            BorderThickness="4" 
            CornerRadius="10" 
            Background="#000000"
            Padding="5">

                <Border BorderBrush="#1a1a1c" 
                BorderThickness="2" 
                CornerRadius="5">

                    <ScrollViewer x:Name="kamera" 
                          HorizontalScrollBarVisibility="Hidden" 
                          VerticalScrollBarVisibility="Hidden" 
                          Background="#1a1a1c">

                        <Canvas x:Name="jatekter" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center">
                        </Canvas>
                    </ScrollViewer>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>