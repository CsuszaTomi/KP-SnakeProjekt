<Window x:Class="KP_SnakeProjekt.Scoreboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Snake – Ranglista" Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0d1117">

    <Grid>
        <!-- Háttér díszek -->
        <Ellipse Width="300" Height="300" Fill="#2f2a1a" HorizontalAlignment="Right"
                 VerticalAlignment="Top" Margin="0,-100,-80,0" Opacity="0.4"/>
        <Ellipse Width="200" Height="200" Fill="#1a2f1a" HorizontalAlignment="Left"
                 VerticalAlignment="Bottom" Margin="-60,0,0,-60" Opacity="0.3"/>

        <StackPanel Margin="40">

            <!-- Cím -->
            <TextBlock Text="🏆" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="RANGLISTA" FontSize="36" FontWeight="Black"
                       Foreground="#fbbf24" HorizontalAlignment="Center"
                       FontFamily="Consolas" Margin="0,0,0,6">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#fbbf24" BlurRadius="18" ShadowDepth="0" Opacity="0.6"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- Fejléc -->
            <Border Background="#161b22" CornerRadius="6" Padding="16,8" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="#" Foreground="#4b5563"
                               FontSize="11" FontWeight="Bold" FontFamily="Consolas"/>
                    <TextBlock Grid.Column="1" Text="JÁTÉKOS" Foreground="#4b5563"
                               FontSize="11" FontWeight="Bold" FontFamily="Consolas"/>
                    <TextBlock Grid.Column="2" Text="ALMA" Foreground="#4b5563"
                               FontSize="11" FontWeight="Bold" FontFamily="Consolas"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Lista -->
            <ScrollViewer MaxHeight="380" VerticalScrollBarVisibility="Hidden">
                <ItemsControl x:Name="lstScores">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="rowBorder" Background="#0f1419" CornerRadius="6"
                                    Padding="16,10" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Place}"
                                               Foreground="#fbbf24" FontSize="14"
                                               FontWeight="Bold" FontFamily="Consolas"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                               Foreground="#e2e8f0" FontSize="14"
                                               FontFamily="Consolas" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="🍎" FontSize="13" Margin="0,0,4,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ScorePoint}" Foreground="#f87171"
                                                   FontSize="14" FontWeight="Bold"
                                                   FontFamily="Consolas" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Vissza gomb -->
            <Button x:Name="btnBack" Content="← VISSZA" Height="42" Margin="0,20,0,0"
                    Background="Transparent" Foreground="#4b5563"
                    FontSize="13" BorderThickness="1" BorderBrush="#1f2937"
                    Cursor="Hand" FontFamily="Consolas" Click="btnBack_Click"/>
        </StackPanel>
    </Grid>
</Window>