<Window x:Class="KP_SnakeProjekt.Register"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KP_SnakeProjekt"
        mc:Ignorable="d"
        Title="Register" Height="550" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0d1117">
    <Grid>
        <Ellipse Width="300" Height="300" Fill="#1a2f1a" HorizontalAlignment="Left"
                 VerticalAlignment="Top" Margin="-100,-80,0,0" Opacity="0.5"/>
        <Ellipse Width="200" Height="200" Fill="#1a2f1a" HorizontalAlignment="Right"
                 VerticalAlignment="Bottom" Margin="0,0,-60,-60" Opacity="0.4"/>
        <StackPanel VerticalAlignment="Center" Margin="50,0">
            <TextBlock Text="Regisztráció" FontSize="42" FontWeight="Black"
                       Foreground="#4ade80" HorizontalAlignment="Center"
                       FontFamily="Consolas" Margin="0,0,0,4">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#4ade80" BlurRadius="18" ShadowDepth="0" Opacity="0.6"/>
                </TextBlock.Effect>
            </TextBlock>
            <!-- Felhasználónév -->
            <TextBlock Text="► felhasználónév" Foreground="#4ade80" FontSize="11"
                       FontFamily="Consolas" Margin="0,0,0,4"/>
            <Border BorderBrush="#4ade80" BorderThickness="1" CornerRadius="4">
                <TextBox x:Name="txtUsername" Height="36" FontSize="14"
                         Background="#0d1117" Foreground="#e2e8f0"
                         BorderThickness="0" Padding="10,6"
                         FontFamily="Consolas" CaretBrush="#4ade80"/>
            </Border>
            <!-- Jelszó -->
            <TextBlock Text="► jelszó" Foreground="#4ade80" FontSize="11"
                       FontFamily="Consolas" Margin="0,15,0,4"/>
            <Border BorderBrush="#4ade80" BorderThickness="1" CornerRadius="4">
                <PasswordBox x:Name="txtPassword" Height="36" FontSize="14"
                             Background="#0d1117" Foreground="#e2e8f0"
                             BorderThickness="0" Padding="10,6"
                             FontFamily="Consolas"/>
            </Border>
            <!-- Jelszó megerősítése -->
            <TextBlock Text="► jelszó megerősítése" Foreground="#4ade80" FontSize="11"
                       FontFamily="Consolas" Margin="0,15,0,4"/>
            <Border BorderBrush="#4ade80" BorderThickness="1" CornerRadius="4">
                <PasswordBox x:Name="txtPasswordConfirm" Height="36" FontSize="14"
                             Background="#0d1117" Foreground="#e2e8f0"
                             BorderThickness="0" Padding="10,6"
                             FontFamily="Consolas"/>
            </Border>
            <!-- Hibaüzenet -->
            <TextBlock x:Name="txtError" Foreground="#f87171" FontSize="12"
                       FontFamily="Consolas" Margin="0,10,0,0"
                       TextWrapping="Wrap" Visibility="Collapsed"/>
            <!-- Regisztráció gomb -->
            <Button x:Name="btnRegister" Height="42" Margin="0,20,0,0"
                    Background="#4ade80" Foreground="#0d1117"
                    FontWeight="Bold" FontSize="15" BorderThickness="0"
                    Cursor="Hand" Click="btnRegister_Click"
                    FontFamily="Consolas">
                <Button.Content>
                    <TextBlock Text="▶  FIÓK LÉTREHOZÁSA" />
                </Button.Content>
            </Button>
            <!-- Vissza a bejelentkezéshez -->
            <Button x:Name="btnBack" Height="38" Margin="0,10,0,0"
                    Background="Transparent" Foreground="#4b5563"
                    FontSize="12" BorderThickness="1" BorderBrush="#1f2937"
                    Cursor="Hand" Click="btnBack_Click"
                    FontFamily="Consolas">
                <Button.Content>
                    <TextBlock Text="← vissza a bejelentkezéshez" />
                </Button.Content>
            </Button>
        </StackPanel>
    </Grid>
</Window>
