<Window x:Class="KP_SnakeProjekt.Settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KP_SnakeProjekt"
        mc:Ignorable="d"
        Title="Beállítások" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0d1117"
        Loaded="Window_Loaded">
    <Grid>
        <!-- Háttér díszek -->
        <Ellipse Width="400" Height="400" Fill="#1a2f1a" HorizontalAlignment="Left"
                 VerticalAlignment="Top" Margin="-150,-150,0,0" Opacity="0.4"/>
        <Ellipse Width="300" Height="300" Fill="#1a1a2f" HorizontalAlignment="Right"
                 VerticalAlignment="Bottom" Margin="0,0,-100,-100" Opacity="0.4"/>
        <Ellipse Width="150" Height="150" Fill="#2f1a2f" HorizontalAlignment="Right"
                 VerticalAlignment="Top" Margin="0,-50,-50,0" Opacity="0.3"/>
        <Ellipse Width="120" Height="120" Fill="#1a2f1a" HorizontalAlignment="Left"
                 VerticalAlignment="Bottom" Margin="-30,0,0,-30" Opacity="0.3"/>

        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- CÍM -->
            <StackPanel Grid.Row="0" Margin="0,0,0,50">
                <TextBlock Text="BEÁLLÍTÁSOK" FontSize="48" FontWeight="Black"
                           Foreground="#a78bfa" HorizontalAlignment="Center"
                           FontFamily="Consolas">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#a78bfa" BlurRadius="24" ShadowDepth="0" Opacity="0.7"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>

            <!-- BEÁLLÍTÁSOK TARTALMA -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Width="500">

                <!-- Pálya mérete szekció -->
                <Border Background="#161b22" CornerRadius="10"
                        BorderBrush="#1f2937" BorderThickness="1"
                        Padding="28,22">
                    <StackPanel>
                        <TextBlock Text="PÁLYA MÉRETE" Foreground="#4b5563"
                                   FontSize="11" FontWeight="Bold"
                                   FontFamily="Consolas" Margin="0,0,0,16"/>

                        <StackPanel x:Name="sizePanel" Orientation="Horizontal" HorizontalAlignment="Center">

                            <!-- 10x10 -->
                            <Button x:Name="btn10" Tag="10"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Margin="10,0" Click="MapSizeButton_Click">
                                <Border x:Name="border10" Width="130" Height="110"
                                        CornerRadius="10" Background="#0d1117"
                                        BorderBrush="#1f2937" BorderThickness="2">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="10×10" Foreground="#a78bfa"
                                                   FontFamily="Consolas" FontSize="22"
                                                   FontWeight="Black" HorizontalAlignment="Center"/>
                                        <TextBlock Text="KIS" Foreground="#4b5563"
                                                   FontFamily="Consolas" FontSize="11"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>

                            <!-- 15x15 -->
                            <Button x:Name="btn15" Tag="15"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Margin="10,0" Click="MapSizeButton_Click">
                                <Border x:Name="border15" Width="130" Height="110"
                                        CornerRadius="10" Background="#0d1117"
                                        BorderBrush="#1f2937" BorderThickness="2">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="15×15" Foreground="#a78bfa"
                                                   FontFamily="Consolas" FontSize="22"
                                                   FontWeight="Black" HorizontalAlignment="Center"/>
                                        <TextBlock Text="KÖZEPES" Foreground="#4b5563"
                                                   FontFamily="Consolas" FontSize="11"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>

                            <!-- 20x20 -->
                            <Button x:Name="btn20" Tag="20"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Margin="10,0" Click="MapSizeButton_Click">
                                <Border x:Name="border20" Width="130" Height="110"
                                        CornerRadius="10" Background="#0d1117"
                                        BorderBrush="#1f2937" BorderThickness="2">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="20×20" Foreground="#a78bfa"
                                                   FontFamily="Consolas" FontSize="22"
                                                   FontWeight="Black" HorizontalAlignment="Center"/>
                                        <TextBlock Text="NAGY" Foreground="#4b5563"
                                                   FontFamily="Consolas" FontSize="11"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>

                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- GOMBOK -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button x:Name="btnSave" Content="MENTÉS"
                        Height="48" Width="200" Margin="0,0,16,0"
                        Background="#a78bfa" Foreground="#0d1117"
                        FontWeight="Bold" FontSize="15" BorderThickness="0"
                        Cursor="Hand" FontFamily="Consolas"
                        Click="btnSave_Click"/>
                <Button x:Name="btnBack" Content="VISSZA"
                        Height="48" Width="200"
                        Background="#161b22" Foreground="#a78bfa"
                        FontSize="15" BorderThickness="1"
                        BorderBrush="#a78bfa" Cursor="Hand"
                        FontFamily="Consolas" Click="btnBack_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>