<Window x:Class="KP_SnakeProjekt.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KP_SnakeProjekt"
        mc:Ignorable="d"
        Loaded="Window_Loaded"
        Title="MainMenu"  Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0d1117">
    <Grid>
        <!-- Háttér díszek -->
        <Ellipse Width="400" Height="400" Fill="#1a2f1a" HorizontalAlignment="Left"
             VerticalAlignment="Top" Margin="-150,-150,0,0" Opacity="0.4"/>
        <Ellipse Width="300" Height="300" Fill="#1a1a2f" HorizontalAlignment="Right"
             VerticalAlignment="Bottom" Margin="0,0,-100,-100" Opacity="0.4"/>
        <Ellipse Width="150" Height="150" Fill="#2f1a2f" HorizontalAlignment="Right"
             VerticalAlignment="Top" Margin="0,-50,-50,0" Opacity="0.3"/>
        <Ellipse Width="120" Height="120" Fill="#1a2f1a" HorizontalAlignment="Left"
             VerticalAlignment="Bottom" Margin="-30,0,0,-30" Opacity="0.3"/>
        <!-- Bejel,Regisz -->
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="30,40,0,0">
            <Button x:Name="btnProfile" Click="btnProfile_Click"
                Background="Transparent" BorderThickness="0" Cursor="Hand"
                HorizontalAlignment="Left">
                <Border Width="110" Height="110" CornerRadius="8"
                    BorderBrush="#4ade80" BorderThickness="2"
                    Background="#161b22">
                    <Canvas Width="60" Height="70" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Canvas.Left="15" Canvas.Top="0" Width="30" Height="30"
                             Stroke="#4ade80" StrokeThickness="2" Fill="Transparent"/>
                        <Path Data="M 0,60 Q 0,35 30,35 Q 60,35 60,60"
                          Stroke="#4ade80" StrokeThickness="2" Fill="Transparent"/>
                    </Canvas>
                </Border>
            </Button>
            <TextBlock x:Name="txtUsername" Text="vendég" FontSize="13"
                   Foreground="#4ade80" FontFamily="Consolas"
                   Margin="0,10,0,0" TextWrapping="Wrap" MaxWidth="160">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#4ade80" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock x:Name="txtMaxScore" Text="" FontSize="11"
                   Foreground="#4b5563" FontFamily="Consolas" Margin="0,4,0,0"/>
        </StackPanel>
        <!-- Fopanel -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">
            <TextBlock Text="KÍGYÓ" FontSize="64" FontWeight="Black"
                   Foreground="#4ade80" HorizontalAlignment="Center"
                   FontFamily="Consolas" Margin="0,0,0,50">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#4ade80" BlurRadius="24" ShadowDepth="0" Opacity="0.7"/>
                </TextBlock.Effect>
            </TextBlock>
            <!-- Játék gomb -->
            <Button x:Name="btnGame" Content="JÁTÉK" Height="52"
                Margin="0,0,0,16" Background="#4ade80" Foreground="#0d1117"
                FontWeight="Bold" FontSize="16" BorderThickness="0"
                Cursor="Hand" FontFamily="Consolas" Click="btnGame_Click"/>
            <!-- Skinek gomb -->
            <Button x:Name="btnSkins" Content="SKINEK" Height="52"
                Margin="0,0,0,16" Background="#161b22" Foreground="#4ade80"
                FontSize="16" BorderThickness="1" BorderBrush="#4ade80"
                Cursor="Hand" FontFamily="Consolas" Click="btnSkins_Click"/>
            <!-- Beállítások gomb -->
            <Button x:Name="btnSettings" Content="BEÁLLÍTÁSOK" Height="52"
                Margin="0,0,0,16" Background="#161b22" Foreground="#a78bfa"
                FontSize="16" BorderThickness="1" BorderBrush="#a78bfa"
                Cursor="Hand" FontFamily="Consolas" Click="btnSettings_Click"/>
            <!-- Kilépés gomb -->
            <Button x:Name="btnExit" Content="KILÉPÉS" Height="44"
                Background="Transparent" Foreground="#4b5563"
                FontSize="14" BorderThickness="1" BorderBrush="#1f2937"
                Cursor="Hand" FontFamily="Consolas" Click="btnExit_Click"/>
        </StackPanel>
    </Grid>
</Window>
